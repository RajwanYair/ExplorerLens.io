        { "ext": "jxl",  "name": "JPEG XL",      "decoder": "JxlDecoder",        "priority": 1, "test_file": "sample.jxl"        },
        { "ext": "tiff", "name": "TIFF",         "decoder": "TiffDecoder",       "priority": 2, "test_file": "sample_rgb.tiff"   },
