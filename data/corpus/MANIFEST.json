{
  "_comment": "ExplorerLens test corpus manifest — generated by tools/Generate-Corpus.ps1",
  "_version": 1,
  "_updated": "2026-04-01",
  "description": "ExplorerLens decoder validation test corpus. Covers top 40 format decoders with representative files.",
  "instructions": [
    "Run `tools/Generate-Corpus.ps1` to create synthetic test files for each entry.",
    "Real-world sample files can be placed in the same subdirectory and will be picked up automatically.",
    "CI validation: .github/workflows/corpus-validation.yml runs lens benchmark against all entries.",
    "Files larger than 10 MB should not be committed — keep them in .gitignore and generate locally."
  ],
  "categories": {
    "images": {
