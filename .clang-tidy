---
# ExplorerLens.io v15.2.0 "Zenith-S" — Clang-Tidy configuration
# Aligned with .clang-format and .github/standards/coding-standards.md
#
# Run: clang-tidy --config-file=.clang-tidy <file> [-- <compiler flags>]
# All suppressed checks are documented with rationale below.

Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-implicit-widening-of-multiplication-result,
  cert-*,
  -cert-err58-cpp,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-init-variables,
  -cppcoreguidelines-macro-usage,
  -cppcoreguidelines-no-malloc,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-owning-memory,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-cstyle-cast,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-union-access,
  -cppcoreguidelines-pro-type-vararg,
  modernize-*,
  -modernize-avoid-c-arrays,
  -modernize-concat-nested-namespaces,
  -modernize-use-nodiscard,
  -modernize-use-trailing-return-type,
  performance-*,
  -performance-avoid-endl,
  readability-*,
  -readability-function-cognitive-complexity,
  -readability-identifier-length,
  -readability-implicit-bool-conversion,
  -readability-magic-numbers,
  -readability-uppercase-literal-suffix,
  misc-*,
  -misc-no-recursion,
  -misc-non-private-member-variables-in-classes,
  concurrency-*,
  -concurrency-mt-unsafe,
  -cppcoreguidelines-avoid-non-const-global-variables

# Suppression rationale:
#   bugprone-easily-swappable-parameters — COM-style (HRESULT, UINT, SIZE*) signatures cause false positives
#   bugprone-implicit-widening-of-multiplication-result — intentional in pixel math (cx * cy * 4)
#   cppcoreguidelines-avoid-magic-numbers — WinAPI constants (IDR_MAINFRAME=128, SM_CXICON) are well-known
#   cppcoreguidelines-avoid-c-arrays — WCHAR[MAX_PATH] is idiomatic Win32
#   cppcoreguidelines-init-variables — ATL output-parameter pattern (HRESULT hr; ...; return hr;)
#   cppcoreguidelines-macro-usage — WTL message maps are macro-based; no alternative
#   cppcoreguidelines-no-malloc — libmupdf / LibRaw use malloc internally
#   cppcoreguidelines-owning-memory — COM AddRef/Release ownership is not gsl::owner-compatible
#   cppcoreguidelines-pro-bounds-array-to-pointer-decay — WCHAR[] to Win32 API is unavoidable
#   cppcoreguidelines-pro-bounds-constant-array-index — test MockDecoder uses variable index in C array (test-only pattern)
#   cppcoreguidelines-pro-bounds-pointer-arithmetic — pixel buffer math (buf + stride*y)
#   cppcoreguidelines-pro-type-cstyle-cast — MAKEINTRESOURCE, HIWORD/LOWORD expand to C casts
#   cppcoreguidelines-pro-type-reinterpret-cast — HBITMAP <-> void* in COM thumbnail path
#   cppcoreguidelines-pro-type-union-access — ULARGE_INTEGER.LowPart / HighPart
#   cppcoreguidelines-pro-type-vararg — OutputDebugStringA / SHFormatMessage
#   modernize-use-nodiscard — planned as a separate cleanup sprint
#   modernize-use-trailing-return-type — team preference is leading return type
#   performance-avoid-endl — std::endl is intentional flush in diagnostics
#   readability-function-cognitive-complexity — format decoders with large switch tables are intentional
#   readability-identifier-length — Win32 loop variables (i, n, hr) are idiomatic
#   readability-implicit-bool-conversion — WTL BOOL(int) <-> bool is idiomatic

WarningsAsErrors: "bugprone-use-after-move,bugprone-dangling-handle,bugprone-unchecked-optional-access,cert-err34-c,cppcoreguidelines-slicing"

HeaderFilterRegex: '^(?!.*(external|packages|gtest|build|build-vcpkg|_deps|x64)).*\.(h|hpp)$'

CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  - key: readability-identifier-naming.ScopedEnumConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.GlobalVariableCase
    value: camelBack
  - key: readability-identifier-naming.GlobalVariablePrefix
    value: g_
  - key: readability-identifier-naming.VariableCase
    value: camelBack
  - key: readability-identifier-naming.ConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: m_
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: modernize-use-nullptr.NullMacros
    value: "NULL"
  - key: performance-unnecessary-value-param.AllowedTypes
    value: "ComPtr;CComPtr;wil::com_ptr"
  - key: bugprone-argument-comment.StrictMode
    value: 'false'
  - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: 'true'
  - key: cppcoreguidelines-special-member-functions.AllowMissingMoveFunctions
    value: 'true'
  - key: misc-include-cleaner.IgnoreHeaders
    value: "windows.h;shlobj.h;thumbcache.h;atlbase.h;atlwin.h;atldlgs.h"
  - key: modernize-loop-convert.MinConfidence
    value: 'reasonable'
  - key: performance-for-range-copy.WarnOnAllAutoCopies
    value: 'true'
