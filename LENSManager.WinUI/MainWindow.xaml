<!-- MainWindow.xaml — ExplorerLens Manager (WinUI 3)
     Main navigation shell: sidebar + page frame for all manager views. -->
<Window
    x:Class="LENSManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LENSManager"
    xmlns:pages="using:LENSManager.Pages"
    Title="ExplorerLens Manager">

    <Grid>
        <NavigationView
            x:Name="NavView"
            OpenPaneLength="220"
            CompactPaneLength="48"
            IsBackButtonVisible="Collapsed"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="DashboardPage" Icon="Home"   Content="Dashboard"
                                    AutomationProperties.HelpText="Live status overview: registration, GPU, cache hit rate, and throughput"/>
                <NavigationViewItem Tag="FormatsPage"   Icon="List"   Content="File Formats"
                                    AutomationProperties.HelpText="Enable or disable thumbnail generation for 200+ file formats"/>
                <NavigationViewItem Tag="GpuPage"       Icon="Video"  Content="GPU Pipeline"
                                    AutomationProperties.HelpText="GPU hardware, DirectX/Vulkan backend, and render pipeline status"/>
                <NavigationViewItem Tag="CachePage"     Icon="Sync"   Content="Cache"
                                    AutomationProperties.HelpText="Thumbnail cache statistics, budget, and clear controls"/>
                <NavigationViewItem Tag="PluginsPage"   Icon="Add"    Content="Plugins"
                                    AutomationProperties.HelpText="Installed decoder plugins and plugin management"/>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Tag="DiagnosticsPage" Icon="Repair" Content="Diagnostics"
                                    AutomationProperties.HelpText="ETW trace capture, decoder health checks, and conflict detection"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="SettingsPage" Icon="Setting" Content="Settings"/>
                <NavigationViewItem Tag="AboutPage"    Icon="Help"    Content="About"/>
            </NavigationView.FooterMenuItems>

            <!-- Header area: version chip + status indicator -->
            <NavigationView.Header>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PageTitle" Grid.Column="0"
                               Style="{StaticResource TitleTextBlockStyle}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Border Background="{StaticResource LensAccentBrush}"
                                CornerRadius="4" Padding="8,2">
                            <TextBlock x:Name="VersionChip" FontSize="11"
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <Ellipse x:Name="StatusDot" Width="10" Height="10"
                                 Fill="{StaticResource LensSuccessBrush}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </NavigationView.Header>

            <!-- Page content frame -->
            <Frame x:Name="ContentFrame" Margin="0,0,0,0"/>

        </NavigationView>
    </Grid>
</Window>
