<!-- GpuPage.xaml — WinUI 3 GPU Pipeline Info Panel
     Sprint 46 (v15.7.0 Modern GUI) — GPU vendor, D3D feature level, VRAM, backend chain -->
<Page
    x:Class="LENSManager.Pages.GpuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LENSManager.Pages"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16" MaxWidth="720">

            <!-- GPU identity card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE7F4;" FontSize="48"
                              Foreground="{StaticResource LensAccentBrush}" Margin="0,0,20,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="GpuName" Text="Detecting…"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock x:Name="GpuVendor" Opacity="0.6"/>
                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="VRAM" FontSize="11" Opacity="0.6"/>
                                <TextBlock x:Name="GpuVram" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="D3D Feature Level" FontSize="11" Opacity="0.6"/>
                                <TextBlock x:Name="D3dFeatureLevel" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Active Backend" FontSize="11" Opacity="0.6"/>
                                <TextBlock x:Name="ActiveBackend" FontWeight="SemiBold"
                                           Foreground="{StaticResource LensAccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Backend waterfall chain -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Backend Waterfall" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="ExplorerLens tries backends top-to-bottom until one succeeds."
                               FontSize="12" Opacity="0.6"/>
                    <ItemsControl x:Name="BackendWaterfall">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Priority}"
                                               FontFamily="{StaticResource LensMonoFont}"
                                               FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontWeight="{Binding IsActive, Converter={StaticResource BoolToFontWeightConverter}}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Description}"
                                               Opacity="0.6" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Status}"
                                               Foreground="{Binding StatusBrush}" FontSize="11"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- GPU Decode Acceleration -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Hardware Video Decode" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NVDEC (NVIDIA)" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="NvdecStatus" Text="—" FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Intel QuickSync" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="QuickSyncStatus" Text="—" FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="AMD AMF" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AmfStatus" Text="—" FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
