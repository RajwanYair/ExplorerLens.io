<Page
    x:Class="ExplorerLens.Manager.Pages.CachePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel Spacing="20">

            <!-- Header -->
            <TextBlock Text="Cache Management"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Monitor and manage the thumbnail cache budget, eviction policy, and sub-millisecond lookup engine."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Cache Stats Cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Hit Rate" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="HitRateText" Text="—"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="cache efficiency" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Entries" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="EntriesText" Text="—"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="cached thumbnails" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Budget Used" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="BudgetUsedText" Text="—"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="of total budget" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Avg Lookup" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="AvgLookupText" Text="&lt;1ms"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="sub-ms cache" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Budget Allocation -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Cache Budget" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Total budget:" VerticalAlignment="Center" Width="120"/>
                        <Slider x:Name="BudgetSlider" Minimum="64" Maximum="4096" Value="512"
                                Width="300" VerticalAlignment="Center"
                                ValueChanged="BudgetSlider_ValueChanged"/>
                        <TextBlock x:Name="BudgetLabel" Text="512 MB"
                                   VerticalAlignment="Center" Width="70"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Max entries:" VerticalAlignment="Center" Width="120"/>
                        <Slider x:Name="MaxEntriesSlider" Minimum="1000" Maximum="100000" Value="50000"
                                Width="300" VerticalAlignment="Center"
                                ValueChanged="MaxEntriesSlider_ValueChanged"/>
                        <TextBlock x:Name="MaxEntriesLabel" Text="50 000"
                                   VerticalAlignment="Center" Width="70"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Hash algorithm:" VerticalAlignment="Center" Width="120"/>
                        <ComboBox x:Name="HashAlgoCombo" Width="200">
                            <ComboBoxItem Content="XXH3 (default / fastest)" IsSelected="True"/>
                            <ComboBoxItem Content="SHA-256 (verified)"/>
                            <ComboBoxItem Content="FNV-1a (compact)"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Eviction Policy -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Eviction Policy" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <ComboBox x:Name="EvictionCombo" Header="Eviction algorithm" Width="300"
                              HorizontalAlignment="Left">
                        <ComboBoxItem Content="LRU — Least Recently Used (default)" IsSelected="True"/>
                        <ComboBoxItem Content="LFU — Least Frequently Used"/>
                        <ComboBoxItem Content="ARC — Adaptive Replacement Cache"/>
                        <ComboBoxItem Content="CLOCK — Clock-Pro approximation"/>
                    </ComboBox>

                    <ToggleSwitch x:Name="PressureEvictionToggle" Header="Enable memory-pressure eviction"
                                  IsOn="True"/>
                    <TextBlock Text="Automatically evicts low-priority entries when system memory pressure exceeds the Medium threshold."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Cache Locations -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Cache Location" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="CacheDirBox"
                                 PlaceholderText="%LOCALAPPDATA%\ExplorerLens\cache"
                                 Width="440" IsReadOnly="True"/>
                        <Button Content="Browse…" Click="BrowseCacheDir_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ClearCacheBtn" Content="Clear Cache" Click="ClearCache_Click"
                                Style="{StaticResource DefaultButtonStyle}"/>
                        <Button x:Name="RebuildIndexBtn" Content="Rebuild Index" Click="RebuildIndex_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
