<Page
    x:Class="ExplorerLens.Manager.Pages.CachePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel Spacing="20">

            <!-- Header -->
            <TextBlock Text="Cache Management"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Monitor and control how thumbnails are stored in memory for fast retrieval. A well-tuned cache means instant previews when you revisit folders."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Cache Stats Cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Hit Rate" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   ToolTipService.ToolTip="Percentage of thumbnail requests served from cache. Aim for >90%. Low = increase cache budget."/>
                        <TextBlock x:Name="HitRateText" Text="—"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="how often thumbnails are found in cache" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Entries" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="EntriesText" Text="—"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="cached thumbnails" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Budget Used" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="BudgetUsedText" Text="—"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="of total budget" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Avg Lookup" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   ToolTipService.ToolTip="Average time to find a cached thumbnail. Under 1ms = excellent performance."/>
                        <TextBlock x:Name="AvgLookupText" Text="&lt;1ms"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="instant cache lookups" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Cache Profile Presets -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick Profiles" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Choose a preset that matches your workload. You can fine-tune individual sliders below."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch" Padding="16,12"
                                Click="ProfileLightweight_Click"
                                ToolTipService.ToolTip="128 MB budget, 10K entries. Best for low-RAM systems or laptops on battery.">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xEC48;" FontSize="24" HorizontalAlignment="Center"
                                          Foreground="{StaticResource LensSuccessBrush}"/>
                                <TextBlock Text="Lightweight" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="128 MB · 10K entries" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" HorizontalAlignment="Stretch" Padding="16,12"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="ProfileBalanced_Click"
                                ToolTipService.ToolTip="512 MB budget, 50K entries. Recommended for most desktops with 8+ GB RAM.">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE81E;" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Text="Balanced" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="512 MB · 50K entries" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" HorizontalAlignment="Stretch" Padding="16,12"
                                Click="ProfilePerformance_Click"
                                ToolTipService.ToolTip="2048 MB budget, 100K entries, ARC eviction. For power users with 16+ GB RAM and large photo libraries.">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE945;" FontSize="24" HorizontalAlignment="Center"
                                          Foreground="{StaticResource LensAccentBrush}"/>
                                <TextBlock Text="Performance" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="2 GB · 100K entries" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Budget Allocation -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Cache Budget" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Total budget:" VerticalAlignment="Center" Width="120"
                                   ToolTipService.ToolTip="Maximum RAM for cached thumbnails. More = faster browsing but uses more memory."/>
                        <Slider x:Name="BudgetSlider" Minimum="64" Maximum="4096" Value="512"
                                Width="300" VerticalAlignment="Center"
                                ValueChanged="BudgetSlider_ValueChanged"/>
                        <TextBlock x:Name="BudgetLabel" Text="512 MB"
                                   VerticalAlignment="Center" Width="70"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Max entries:" VerticalAlignment="Center" Width="120"
                                   ToolTipService.ToolTip="Maximum number of individual files that can be cached. Increase if you browse folders with many files."/>
                        <Slider x:Name="MaxEntriesSlider" Minimum="1000" Maximum="100000" Value="50000"
                                Width="300" VerticalAlignment="Center"
                                ValueChanged="MaxEntriesSlider_ValueChanged"/>
                        <TextBlock x:Name="MaxEntriesLabel" Text="50 000"
                                   VerticalAlignment="Center" Width="70"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Hash algorithm:" VerticalAlignment="Center" Width="120"
                                   ToolTipService.ToolTip="Algorithm used to identify cached files. XXH3 is fastest and recommended for most users."/>
                        <ComboBox x:Name="HashAlgoCombo" Width="200">
                            <ComboBoxItem Content="XXH3 (default / fastest)" IsSelected="True"/>
                            <ComboBoxItem Content="SHA-256 (verified)"/>
                            <ComboBoxItem Content="FNV-1a (compact)"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Eviction Policy -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Eviction Policy" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="When the cache is full, which items to remove first. LRU (default) removes the oldest unused items."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,4"/>

                    <ComboBox x:Name="EvictionCombo" Header="Eviction algorithm" Width="300"
                              HorizontalAlignment="Left">
                        <ComboBoxItem Content="LRU — Least Recently Used (default)" IsSelected="True"/>
                        <ComboBoxItem Content="LFU — Least Frequently Used"/>
                        <ComboBoxItem Content="ARC — Adaptive Replacement Cache"/>
                        <ComboBoxItem Content="CLOCK — Clock-Pro approximation"/>
                    </ComboBox>

                    <ToggleSwitch x:Name="PressureEvictionToggle" Header="Enable memory-pressure eviction"
                                  IsOn="True"/>
                    <TextBlock Text="Automatically evicts low-priority entries when system memory pressure exceeds the Medium threshold."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Cache Locations -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Cache Location" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="CacheDirBox"
                                 PlaceholderText="%LOCALAPPDATA%\ExplorerLens\cache"
                                 Width="440" IsReadOnly="True"/>
                        <Button Content="Browse…" Click="BrowseCacheDir_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ClearCacheBtn" Content="Clear Cache" Click="ClearCache_Click"
                                Style="{StaticResource DefaultButtonStyle}"/>
                        <Button x:Name="RebuildIndexBtn" Content="Rebuild Index" Click="RebuildIndex_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
