<!-- SettingsPage.xaml — Application Settings
     Thumbnail rendering, GPU backend, cache, and appearance preferences. -->
<Page
    x:Class="LENSManager.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LENSManager.Pages"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="8" MaxWidth="640">

            <!-- Section: Thumbnail rendering -->
            <TextBlock Text="Thumbnail Rendering" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,4"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <!-- Thumbnail size -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Default Thumbnail Size" FontWeight="SemiBold"/>
                            <TextBlock Text="Fallback size when Windows does not request a specific one. Larger = sharper but slower. 256 px is recommended." Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="ThumbnailSizeBox" VerticalAlignment="Center">
                            <ComboBoxItem Content="128 px"/>
                            <ComboBoxItem Content="256 px" IsSelected="True"/>
                            <ComboBoxItem Content="512 px"/>
                            <ComboBoxItem Content="1024 px"/>
                        </ComboBox>
                    </Grid>

                    <!-- GPU backend -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GPU Backend" FontWeight="SemiBold"/>
                            <TextBlock Text="Which graphics library to use. Auto detects the best option. CPU-only is slower but works on all systems." Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="GpuBackendBox" VerticalAlignment="Center">
                            <ComboBoxItem Content="Auto (recommended)" IsSelected="True"/>
                            <ComboBoxItem Content="DirectX 12"/>
                            <ComboBoxItem Content="DirectX 11"/>
                            <ComboBoxItem Content="Vulkan Compute"/>
                            <ComboBoxItem Content="CPU only"/>
                        </ComboBox>
                    </Grid>

                    <!-- Quality vs speed tradeoff -->
                    <StackPanel>
                        <TextBlock Text="Quality Mode" FontWeight="SemiBold"/>
                        <TextBlock Text="Controls the speed vs. quality tradeoff for thumbnail rendering. Balanced is recommended for everyday use." Opacity="0.6" FontSize="12" Margin="0,0,0,4"/>
                        <RadioButtons>
                            <RadioButton Content="Speed — Fastest rendering, slightly lower quality"/>
                            <RadioButton Content="Balanced — Recommended for everyday Explorer browsing" IsChecked="True"/>
                            <RadioButton Content="Quality — Best output, takes longer per thumbnail"/>
                        </RadioButtons>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Section: Cache -->
            <TextBlock Text="Cache" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,4"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Cache Budget (MB)" FontWeight="SemiBold"/>
                            <TextBlock Text="RAM allocated for caching thumbnails. More = faster repeat browsing. 512 MB is fine for most users." Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <NumberBox Grid.Column="1" x:Name="CacheBudgetBox"
                                   Minimum="64" Maximum="4096" Value="512"
                                   SpinButtonPlacementMode="Inline"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Enable Hot-Mode Cache" FontWeight="SemiBold"/>
                            <TextBlock Text="Keep recently-viewed thumbnails pinned in memory for instant re-display. Recommended on systems with 8+ GB RAM." Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="HotModeEnabled" IsOn="True"
                                      OnContent="" OffContent="" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Content="Clear Cache Now" Click="ClearCache_Click"/>
                </StackPanel>
            </Border>

            <!-- Section: Appearance -->
            <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,4"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="App Theme" FontWeight="SemiBold"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="ThemeBox" VerticalAlignment="Center">
                            <ComboBoxItem Content="System default" IsSelected="True"/>
                            <ComboBoxItem Content="Dark"/>
                            <ComboBoxItem Content="Light"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <Button Style="{StaticResource AccentButtonStyle}" Content="Save Settings"
                    Click="SaveSettings_Click" Margin="0,8,0,0" HorizontalAlignment="Right"/>

        </StackPanel>
    </ScrollViewer>
</Page>
