<Page
    x:Class="ExplorerLens.Manager.Pages.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="24,16" RowSpacing="16">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Plugin Manager"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Install, enable, and configure third-party decoder and thumbnail plugins via the ExplorerLens Plugin SDK."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox x:Name="PluginSearchBox" Grid.Column="0"
                            PlaceholderText="Search plugins…"
                            QueryIcon="Find" MaxWidth="400"
                            HorizontalAlignment="Left"
                            TextChanged="PluginSearch_TextChanged"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Click="BrowseMarketplace_Click"
                        ToolTipService.ToolTip="Browse the ExplorerLens Plugin Marketplace to discover new decoders and thumbnail providers">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A9;" FontSize="14"/>
                        <TextBlock Text="Browse Marketplace"/>
                    </StackPanel>
                </Button>
                <Button Content="Install from file…" Click="InstallPlugin_Click"
                        ToolTipService.ToolTip="Install a .lenspkg plugin file from your local disk"/>
                <Button Click="UpdatePlugins_Click"
                        ToolTipService.ToolTip="Check for newer versions of all installed plugins">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="Check for Updates"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Plugin List -->
        <ListView x:Name="PluginListView" Grid.Row="2"
                  SelectionMode="Single"
                  SelectionChanged="PluginListView_SelectionChanged">

            <ListView.Header>
                <Grid Padding="16,8" Background="{ThemeResource LayerFillColorDefaultBrush}"
                      ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Plugin" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Publisher" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Version" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Trust" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="Enabled" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Description}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Publisher}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Version}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding TrustLevel}" VerticalAlignment="Center"/>
                        <ToggleSwitch Grid.Column="4" IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <!-- Empty state -->
            <ListView.Footer>
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                            Margin="0,48" Spacing="16" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE7FC;" FontSize="48"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No plugins installed yet"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Plugins extend ExplorerLens with new decoders and thumbnail providers.&#x0a;Browse the marketplace or install a .lenspkg file to get started."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="420"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Button Content="Browse Marketplace" HorizontalAlignment="Center"
                                Click="BrowseMarketplace_Click"
                                Style="{StaticResource AccentButtonStyle}"/>
                        <Button Content="Install from file…" HorizontalAlignment="Center"
                                Click="InstallPlugin_Click"/>
                    </StackPanel>
                    <HyperlinkButton Content="Read the Plugin Development Guide"
                                     NavigateUri="https://github.com/RajwanYair/ExplorerLens/blob/main/docs/PLUGIN_DEVELOPMENT.md"
                                     HorizontalAlignment="Center"/>
                </StackPanel>
            </ListView.Footer>
        </ListView>

    </Grid>
</Page>
