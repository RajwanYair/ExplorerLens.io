<!-- FormatsPage.xaml — File Format Manager
     Search, filter, and toggle 200+ supported file format handlers. -->
<Page
    x:Class="LENSManager.Pages.FormatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LENSManager.Pages"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search + filter bar -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <AutoSuggestBox Grid.Column="0"
                            PlaceholderText="Search by name, extension, decoder, or MIME type (e.g. webp, PDFDecoder, image/avif)"
                            QueryIcon="Find" x:Name="FormatSearch"
                            TextChanged="FormatSearch_TextChanged"
                            ToolTipService.ToolTip="Type a format name (.webp), description (WebP), decoder class (WebPDecoder), or MIME type (image/webp) to filter the list"/>
            <ComboBox Grid.Column="1" x:Name="CategoryFilter"
                      PlaceholderText="All categories"
                      SelectionChanged="CategoryFilter_SelectionChanged">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Images"/>
                <ComboBoxItem Content="Archives"/>
                <ComboBoxItem Content="Documents"/>
                <ComboBoxItem Content="RAW Camera"/>
                <ComboBoxItem Content="Video"/>
                <ComboBoxItem Content="Audio"/>
                <ComboBoxItem Content="3D Models"/>
                <ComboBoxItem Content="CAD/BIM"/>
                <ComboBoxItem Content="Scientific"/>
                <ComboBoxItem Content="Fonts"/>
                <ComboBoxItem Content="Source Code"/>
            </ComboBox>
            <ComboBox Grid.Column="2" x:Name="GpuFilter"
                      PlaceholderText="Any GPU status"
                      SelectionChanged="GpuFilter_SelectionChanged"
                      ToolTipService.ToolTip="Filter formats by GPU acceleration support">
                <ComboBoxItem Content="Any"/>
                <ComboBoxItem Content="GPU Accelerated"/>
                <ComboBoxItem Content="CPU Only"/>
            </ComboBox>
            <ToggleButton Grid.Column="3" x:Name="ShowRegisteredOnly"
                          Content="Registered only" IsChecked="False"
                          ToolTipService.ToolTip="Show only formats currently registered with Windows Explorer. Registered formats generate thumbnails when you browse."
                          Checked="ShowRegisteredOnly_Changed"
                          Unchecked="ShowRegisteredOnly_Changed"/>
        </Grid>

        <!-- Format count + batch action bar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:Name="FormatCountLabel" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                <HyperlinkButton Content="Register all" Click="RegisterAll_Click" FontSize="12"/>
                <HyperlinkButton Content="Register category" Click="RegisterCategory_Click" FontSize="12"
                                 ToolTipService.ToolTip="Register all formats in the currently selected category"/>
                <HyperlinkButton Content="Unregister all" Click="UnregisterAll_Click" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Apply Changes" Style="{StaticResource AccentButtonStyle}"
                        Click="ApplyChanges_Click"
                        ToolTipService.ToolTip="Write all format registration changes to the Windows registry and restart Explorer"/>
                <Button Content="Discard" Click="DiscardChanges_Click"
                        ToolTipService.ToolTip="Revert all unsaved toggle changes"/>
            </StackPanel>
        </Grid>

        <!-- Format list -->
        <ListView Grid.Row="2" x:Name="FormatList" SelectionMode="Single"
                  SelectionChanged="FormatList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <!-- Extension badge -->
                        <Border Grid.Column="0" Background="{StaticResource LensAccentBrush}"
                                CornerRadius="4" Padding="4,2" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Extension}" FontFamily="{StaticResource LensMonoFont}"
                                       FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Description}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Decoder}" Opacity="0.7"
                                   FontFamily="{StaticResource LensMonoFont}" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding MimeType}" Opacity="0.5"
                                   FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="{Binding GpuAccelerated}" Opacity="0.7"
                                   VerticalAlignment="Center"/>
                        <ToggleSwitch Grid.Column="5" x:Name="FormatEnabled"
                                      IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                      OnContent="" OffContent=""
                                      Toggled="FormatToggled"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Format Detail Panel (shown when a format is selected) -->
        <Border Grid.Row="3" x:Name="DetailPanel" Visibility="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16" MaxHeight="140">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Format Details" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DetailExtension" FontFamily="{StaticResource LensMonoFont}" FontSize="18"
                               Foreground="{StaticResource LensAccentBrush}"/>
                    <TextBlock x:Name="DetailDescription" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Decoder" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="DetailDecoder" FontFamily="{StaticResource LensMonoFont}" FontSize="11"/>
                    <TextBlock Text="MIME Type" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock x:Name="DetailMime" FontFamily="{StaticResource LensMonoFont}" FontSize="11" Opacity="0.7"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Performance" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="DetailLatency" FontSize="11"/>
                    <TextBlock Text="GPU" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock x:Name="DetailGpu" FontSize="11"/>
                </StackPanel>
                <Button Grid.Column="3" Content="Test Decode" VerticalAlignment="Center"
                        Click="TestDecode_Click"
                        ToolTipService.ToolTip="Generate a test thumbnail for this format with a sample file to verify the decoder is working"/>
            </Grid>
        </Border>

    </Grid>
</Page>
