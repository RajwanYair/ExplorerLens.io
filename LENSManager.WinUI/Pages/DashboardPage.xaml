<!-- DashboardPage.xaml — Live Status Overview
     Thumbnail pipeline status cards, recent activity, and throughput metrics. -->
<Page
    x:Class="LENSManager.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LENSManager.Pages"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16">

            <!-- Status cards row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Registration status -->
                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,0"
                        ToolTipService.ToolTip="Whether the ExplorerLens COM shell extension is registered with Windows Explorer">
                    <StackPanel>
                        <FontIcon Glyph="&#xE7BA;" FontSize="24" Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Text="Shell Extension" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock x:Name="RegistrationStatus" Text="Registered" FontWeight="SemiBold"
                                   Foreground="{StaticResource LensSuccessBrush}"/>
                    </StackPanel>
                </Border>

                <!-- GPU status -->
                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,0"
                        ToolTipService.ToolTip="Active GPU render backend used for thumbnail generation">
                    <StackPanel>
                        <FontIcon Glyph="&#xE7F4;" FontSize="24" Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Text="GPU Acceleration" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock x:Name="GpuStatus" Text="DirectX 12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Cache hit rate -->
                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,0"
                        ToolTipService.ToolTip="Percentage of thumbnail requests served from cache without re-decoding">
                    <StackPanel>
                        <FontIcon Glyph="&#xE82D;" FontSize="24" Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Text="Cache Hit Rate" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock x:Name="CacheHitRate" Text="94.2%" FontWeight="SemiBold"
                                   Foreground="{StaticResource LensSuccessBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Thumbnails generated -->
                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16"
                        ToolTipService.ToolTip="Total thumbnails generated since this Explorer session started">
                    <StackPanel>
                        <FontIcon Glyph="&#xE8B9;" FontSize="24" Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Text="Thumbnails / Session" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock x:Name="ThumbnailCount" Text="0" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent activity -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Recent Activity" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                    <ListView x:Name="ActivityList" MaxHeight="200" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8B9;" FontSize="14" Margin="0,0,8,0" Opacity="0.6"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Duration}" Opacity="0.6" FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Throughput sparkline chart -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" MinHeight="160">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Throughput (last 60s)" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                            <TextBlock x:Name="ThroughputLabel" Text="235 img/s"
                                       FontFamily="{StaticResource LensMonoFont}"
                                       Foreground="{StaticResource LensAccentBrush}" FontWeight="Bold" FontSize="18"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ThroughputDelta" Text="↑ 12%" FontSize="11"
                                       Foreground="{StaticResource LensSuccessBrush}" VerticalAlignment="Center"
                                       ToolTipService.ToolTip="Change compared to previous 60-second window"/>
                        </StackPanel>
                    </Grid>
                    <!-- Canvas-based sparkline: 60 data points (1 per second) rendered as polyline -->
                    <Canvas x:Name="SparklineCanvas" Height="80" Margin="0,8,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Thumbnails generated per second over the last 60 seconds"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="60s ago" FontSize="10" Opacity="0.4"/>
                        <TextBlock Grid.Column="1" Text="now" FontSize="10" Opacity="0.4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Format breakdown -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Format Breakdown (this session)" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                    <Grid ColumnSpacing="8" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <!-- Row 0: JPEG -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="JPEG" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="0" Grid.Column="1" Value="42" Maximum="100" Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="42%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 1: PNG -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="PNG" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="1" Grid.Column="1" Value="23" Maximum="100" Foreground="{StaticResource LensSecondaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="23%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 2: RAW -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="RAW" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="2" Grid.Column="1" Value="15" Maximum="100" Foreground="{StaticResource LensSuccessBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="15%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 3: WebP -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="WebP" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="3" Grid.Column="1" Value="11" Maximum="100" Foreground="{StaticResource LensWarningBrush}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="11%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 4: Other -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Other" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="4" Grid.Column="1" Value="9" Maximum="100"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="9%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Quick Actions" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickClearCache_Click"
                                ToolTipService.ToolTip="Remove all cached thumbnails. Explorer will regenerate them on next browse.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE74D;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Clear Cache" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickRestart_Click"
                                ToolTipService.ToolTip="Restart Windows Explorer to apply changes and refresh all folder thumbnails.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE72C;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Restart Explorer" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickExport_Click"
                                ToolTipService.ToolTip="Save a diagnostic bundle .zip for support or bug reports.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xEDE1;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Export Logs" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickFormats_Click"
                                ToolTipService.ToolTip="Jump to File Formats page to enable or disable specific format handlers.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7C4;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Manage Formats" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid
                        <TextBlock Text="Throughput (last 60s)" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                            <TextBlock x:Name="ThroughputLabel" Text="235 img/s"
                                       FontFamily="{StaticResource LensMonoFont}"
                                       Foreground="{StaticResource LensAccentBrush}" FontWeight="Bold" FontSize="18"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ThroughputDelta" Text="↑ 12%" FontSize="11"
                                       Foreground="{StaticResource LensSuccessBrush}" VerticalAlignment="Center"
                                       ToolTipService.ToolTip="Change compared to previous 60-second window"/>
                        </StackPanel>
                    </Grid>
                    <!-- Canvas-based sparkline: 60 data points (1 per second) rendered as polyline -->
                    <Canvas x:Name="SparklineCanvas" Height="80" Margin="0,8,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Thumbnails generated per second over the last 60 seconds"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="60s ago" FontSize="10" Opacity="0.4"/>
                        <TextBlock Grid.Column="1" Text="now" FontSize="10" Opacity="0.4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Format breakdown -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Format Breakdown (this session)" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                    <Grid ColumnSpacing="8" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <!-- Row 0: JPEG -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="JPEG" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="0" Grid.Column="1" Value="42" Maximum="100" Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="42%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 1: PNG -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="PNG" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="1" Grid.Column="1" Value="23" Maximum="100" Foreground="{StaticResource LensSecondaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="23%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 2: RAW -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="RAW" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="2" Grid.Column="1" Value="15" Maximum="100" Foreground="{StaticResource LensSuccessBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="15%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 3: WebP -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="WebP" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="3" Grid.Column="1" Value="11" Maximum="100" Foreground="{StaticResource LensWarningBrush}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="11%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- Row 4: Other -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Other" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Row="4" Grid.Column="1" Value="9" Maximum="100"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="9%" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Quick Actions" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickClearCache_Click"
                                ToolTipService.ToolTip="Remove all cached thumbnails. Explorer will regenerate them on next browse.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE74D;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Clear Cache" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickRestart_Click"
                                ToolTipService.ToolTip="Restart Windows Explorer to apply changes and refresh all folder thumbnails.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE72C;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Restart Explorer" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickExport_Click"
                                ToolTipService.ToolTip="Save a diagnostic bundle .zip for support or bug reports.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xEDE1;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Export Logs" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" HorizontalAlignment="Stretch" Padding="12,10"
                                Click="QuickFormats_Click"
                                ToolTipService.ToolTip="Jump to File Formats page to enable or disable specific format handlers.">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7C4;" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Manage Formats" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
