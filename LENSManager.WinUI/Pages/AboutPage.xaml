<!-- AboutPage.xaml — Version, License & Links
     Displays current version, quick stats, documentation links, and licensing info. -->
<Page
    x:Class="LENSManager.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LENSManager.Pages"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Center">

            <!-- Logo and title -->
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <!-- Lens icon using Segoe Fluent Icons -->
                <FontIcon Glyph="&#xE7BA;" FontSize="64" Foreground="{StaticResource LensAccentBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="ExplorerLens" Style="{StaticResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="VersionLabel" Text="v33.0.0 (Spica)"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" Opacity="0.7"/>
                <TextBlock Text="GPU-Accelerated Thumbnail Provider for Windows Explorer"
                           HorizontalAlignment="Center" Opacity="0.6" TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Quick stats -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="200+" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                                   Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Text="File Formats" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="Images, archives, docs, 3D" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="25+" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                                   Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Text="Decoders" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="Specialized per format" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="&lt;17ms" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                                   Foreground="{StaticResource LensAccentBrush}"/>
                        <TextBlock Text="Per Thumbnail" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="GPU-accelerated average" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Links -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Links" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <HyperlinkButton Content="GitHub Repository"
                                     NavigateUri="https://github.com/RajwanYair/ExplorerLens.io"/>
                    <HyperlinkButton Content="Documentation"
                                     NavigateUri="https://github.com/RajwanYair/ExplorerLens.io/blob/main/README.md"/>
                    <HyperlinkButton Content="Report a Bug"
                                     NavigateUri="https://github.com/RajwanYair/ExplorerLens.io/issues/new"/>
                    <HyperlinkButton Content="CHANGELOG"
                                     NavigateUri="https://github.com/RajwanYair/ExplorerLens.io/blob/main/CHANGELOG.md"/>
                </StackPanel>
            </Border>

            <!-- License -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="License" FontWeight="SemiBold"/>
                    <TextBlock Text="MIT License — Copyright (c) 2026 ExplorerLens Project"
                               Opacity="0.7" TextWrapping="Wrap" FontSize="12"/>
                    <TextBlock Text="External libraries retain their respective open-source licenses."
                               Opacity="0.6" TextWrapping="Wrap" FontSize="11"/>
                    <HyperlinkButton Content="View SBOM (Software Bill of Materials)"
                                     NavigateUri="https://github.com/RajwanYair/ExplorerLens.io/blob/main/docs/SBOM.json"
                                     FontSize="11"/>
                </StackPanel>
            </Border>

            <!-- Build info + System snapshot -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="System Info" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid ColumnSpacing="16" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Build" Opacity="0.6" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BuildInfo"
                                   FontFamily="{StaticResource LensMonoFont}" FontSize="11"
                                   Text="MSVC v145 | x64 | Release"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="GPU" Opacity="0.6" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GpuInfo"
                                   FontFamily="{StaticResource LensMonoFont}" FontSize="11"
                                   Text="(detecting...)"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Windows" Opacity="0.6" FontSize="12"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="WindowsInfo"
                                   FontFamily="{StaticResource LensMonoFont}" FontSize="11"
                                   Text="(detecting...)"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Shell CLSID" Opacity="0.6" FontSize="12"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   FontFamily="{StaticResource LensMonoFont}" FontSize="11"
                                   Text="{9E6ECB90-5A61-42BD-B851-D3297D9C7F39}" IsTextSelectionEnabled="True"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Tests" Opacity="0.6" FontSize="12"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   FontFamily="{StaticResource LensMonoFont}" FontSize="11"
                                   Text="4583 passed | 0 failed | 100% pass rate"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="Copy System Info" Click="CopySystemInfo_Click" FontSize="12"
                                ToolTipService.ToolTip="Copy all system details to clipboard for pasting in bug reports"/>
                        <Button Content="Check for Updates" Click="CheckForUpdates_Click" FontSize="12"
                                ToolTipService.ToolTip="Check if a newer version of ExplorerLens is available on GitHub"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
