<!-- App.xaml — WinUI 3 Application Resources
     Sprint 41 (v15.7.0 Modern GUI)
     Defines global theme resources: AccentColor, FluentDark/Light themes,
     NavigationView styles, and font overrides. -->
<Application
    x:Class="LENSManager.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LENSManager">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WinUI 3 built-in theme resources -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ExplorerLens accent colour: matches GitHub Copilot blue -->
            <Color x:Key="LensAccentColor">#2F81F7</Color>
            <Color x:Key="LensSecondaryColor">#8957E5</Color>
            <Color x:Key="LensSuccessColor">#3FB950</Color>
            <Color x:Key="LensWarningColor">#D29922</Color>
            <Color x:Key="LensErrorColor">#F85149</Color>

            <!-- Application background: dark navy -->
            <Color x:Key="LensBackgroundDark">#0D1117</Color>
            <Color x:Key="LensSurfaceDark">#161B22</Color>
            <Color x:Key="LensBorderDark">#30363D</Color>

            <SolidColorBrush x:Key="LensAccentBrush" Color="{StaticResource LensAccentColor}"/>
            <SolidColorBrush x:Key="LensSecondaryBrush" Color="{StaticResource LensSecondaryColor}"/>

            <!-- NavigationView overrides for Fluent dark sidebar -->
            <Style TargetType="NavigationView">
                <Setter Property="OpenPaneLength" Value="220"/>
                <Setter Property="CompactPaneLength" Value="48"/>
                <Setter Property="IsTabStop" Value="False"/>
            </Style>

            <!-- Global font: Segoe UI Variable is bundled with Windows 11+;
                 fall back to Segoe UI on Windows 10 -->
            <FontFamily x:Key="LensFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
            <FontFamily x:Key="LensMonoFont">Cascadia Code, Consolas, monospace</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
