    IDS_SETTING_TELEMETRY   "Anonyme Diagnose"

    // Errors
    IDS_ERR_REG_ADMIN       "Zum Registrieren der Shell-Erweiterung sind Administratorrechte erforderlich."
    IDS_ERR_DLL_NOT_FOUND   "LENSShell.dll nicht gefunden.  Bitte ExplorerLens neu installieren."
    IDS_ERR_GPU_INIT        "GPU-Initialisierung fehlgeschlagen.  Rückfall auf CPU-Rendering."
    IDS_ERR_CACHE_CORRUPT   "Cache-Index ist beschädigt.  Wird neu aufgebaut..."
    IDS_ERR_PLUGIN_TRUST    "Plugin \"%s\" hat die Vertrauensverifizierung nicht bestanden und wurde nicht geladen."
