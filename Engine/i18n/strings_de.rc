    IDS_GPU_CPU             "CPU-Fallback"

    // Settings
    IDS_SETTING_QUALITY     "Miniaturqualität"
    IDS_SETTING_CACHE_SIZE  "Cache-Budget (MB)"
    IDS_SETTING_MAX_ENTRIES "Max. Cache-Einträge"
