    // Status messages
    IDS_STATUS_REGISTERED   "Erweiterung registriert"
    IDS_STATUS_UNREGISTERED "Erweiterung nicht registriert"
    IDS_STATUS_PROCESSING   "Miniaturbilder werden erstellt..."
    IDS_STATUS_IDLE         "Leerlauf"
    IDS_STATUS_ERROR        "Fehler: %s"

    // Dashboard
    IDS_DASH_HIT_RATE       "Cache-Trefferquote"
    IDS_DASH_THUMBNAILS     "Erstellte Miniaturbilder"
    IDS_DASH_GPU_BACKEND    "GPU-Backend"
    IDS_DASH_THROUGHPUT     "Durchsatz"

    // Actions
    IDS_ACTION_ENABLE       "Erweiterung aktivieren"
    IDS_ACTION_DISABLE      "Erweiterung deaktivieren"
    IDS_ACTION_CLEAR_CACHE  "Cache leeren"
    IDS_ACTION_OPEN_MGR     "LENSManager öffnen"
    IDS_ACTION_REGISTER     "Shell-Erweiterung registrieren"
    IDS_ACTION_UNREGISTER   "Shell-Erweiterung entregistrieren"

    // GPU backends
    IDS_GPU_AUTO            "Automatische Erkennung (empfohlen)"
    IDS_GPU_DX12            "DirectX 12"
    IDS_GPU_DX11            "DirectX 11"
