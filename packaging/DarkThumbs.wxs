<?xml version="1.0" encoding="UTF-8"?>
<!--
  DarkThumbs Windows Installer (WiX Toolset 4.x/5.x)
  Sprint 23: Packaging & Deployment
  
  Build Instructions:
    wix build DarkThumbs.wxs -out DarkThumbs-Setup-6.2.0.msi
  
  Prerequisites:
    - WiX Toolset v4.0.5+ or v5.0+
    - .NET SDK 8.0+
    - All binaries built in Release configuration
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  
  <!-- Product Information -->
  <Product Id="*"
           Name="DarkThumbs"
           Language="1033"
           Version="6.2.0.0"
           Manufacturer="DarkThumbs Project"
           UpgradeCode="A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
    
    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="DarkThumbs - GPU-Accelerated Windows Thumbnail Provider"
             Comments="150+ file format thumbnail generation for Windows Explorer"
             Manufacturer="DarkThumbs Project" />
    
    <!-- Upgrade Logic -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  AllowSameVersionUpgrades="yes" />
    
    <!-- Installation Media -->
    <MediaTemplate EmbedCab="yes" />
    
    <!-- Installation Features -->
    <Feature Id="MainFeature" 
             Title="DarkThumbs Core" 
             Description="Core thumbnail provider shell extension"
             Level="1"
             ConfigurableDirectory="INSTALLFOLDER"
             AllowAdvertise="no">
      
      <!-- Core Components -->
      <ComponentGroupRef Id="CoreComponents" />
      <ComponentGroupRef Id="ExternalLibraries" />
      <ComponentGroupRef Id="RegistryEntries" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
    </Feature>
    
    <Feature Id="ManagerFeature"
             Title="CBXManager Configuration Tool"
             Description="Graphical configuration utility"
             Level="1"
             AllowAdvertise="no">
      <ComponentGroupRef Id="ManagerComponents" />
    </Feature>
    
    <Feature Id="DebugSymbolsFeature"
             Title="Debug Symbols (PDB files)"
             Description="Debug symbols for troubleshooting"
             Level="2"
             AllowAdvertise="no">
      <ComponentGroupRef Id="DebugComponents" />
    </Feature>
  </Product>
  
  <!-- Directory Structure -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DarkThumbs">
        <Directory Id="BinFolder" Name="bin" />
        <Directory Id="LibFolder" Name="lib" />
        <Directory Id="DocsFolder" Name="docs" />
      </Directory>
    </StandardDirectory>
    
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DarkThumbs" />
    </StandardDirectory>
  </Fragment>
  
  <!-- Core Components -->
  <Fragment>
    <ComponentGroup Id="CoreComponents" Directory="BinFolder">
      <!-- Shell Extension COM DLL -->
      <Component Id="CBXShellDLL" Guid="B8394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <File Id="CBXShellDLL" 
              Source="$(var.BuildDir)\CBXShell\x64\Release\CBXShell.dll"
              KeyPath="yes"
              Checksum="yes">
          <!-- COM Registration -->
          <RegistryValue Root="HKCR" 
                         Key="CLSID\{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" 
                         Value="DarkThumbs Thumbnail Provider"
                         Type="string" />
        </File>
      </Component>
      
      <!-- Engine Library --
>
      <Component Id="EngineLibrary" Guid="C8394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <File Id="DarkThumbsEngine"
              Source="$(var.BuildDir)\build\lib\Release\DarkThumbsEngine.lib"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
    
    <!-- External Dependencies -->
    <ComponentGroup Id="ExternalLibraries" Directory="BinFolder">
      <Component Id="LibWebP" Guid="D8394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <File Source="$(var.BuildDir)\external\image-libs\libwebp-1.5.0-build\libwebp.dll" />
      </Component>
      
      <Component Id="LibAvif" Guid="E8394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <File Source="$(var.BuildDir)\external\image-libs\libavif-1.3.0\build\Release\avif.dll" />
      </Component>
      
      <Component Id="LibJXL" Guid="F8394D0D-EE2B-4A00-9FAC-AB8D3B03F078" Condition="HAS_LIBJXL">
        <File Source="$(var.BuildDir)\external\image-libs\libjxl-0.11.1\install\bin\jxl.dll" />
      </Component>
    </ComponentGroup>
    
    <!-- Manager Application -->
    <ComponentGroup Id="ManagerComponents" Directory="BinFolder">
      <Component Id="CBXManagerEXE" Guid="18394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <File Id="CBXManagerEXE"
              Source="$(var.BuildDir)\CBXManager\x64\Release\CBXManager.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
    
    <!-- Debug Symbols -->
    <ComponentGroup Id="DebugComponents" Directory="BinFolder">
      <Component Id="CBXShellPDB" Guid="28394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <File Source="$(var.BuildDir)\CBXShell\x64\Release\CBXShell.pdb" />
      </Component>
      
      <Component Id="CBXManagerPDB" Guid="38394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <File Source="$(var.BuildDir)\CBXManager\x64\Release\CBXManager.pdb" />
      </Component>
    </ComponentGroup>
    
    <!-- Registry Entries -->
    <ComponentGroup Id="RegistryEntries" Directory="INSTALLFOLDER">
      <Component Id="ThumbnailProviderRegistry" Guid="48394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <!-- Register as Thumbnail Provider for supported extensions -->
        <RegistryKey Root="HKCR" Key=".cbz\shellex\{e357fccd-a995-4576-b01f-234630154e96}">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
        
        <RegistryKey Root="HKCR" Key=".cbr\shellex\{e357fccd-a995-4576-b01f-234630154e96}">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
        
        <RegistryKey Root="HKCR" Key=".cb7\shellex\{e357fccd-a995-4576-b01f-234630154e96}">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
        
        <!-- WebP -->
        <RegistryKey Root="HKCR" Key=".webp\shellex\{e357fccd-a995-4576-b01f-234630154e96}">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
        
        <!-- AVIF -->
        <RegistryKey Root="HKCR" Key=".avif\shellex\{e357fccd-a995-4576-b01f-234630154e96}">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
        
        <!-- JPEG XL -->
        <RegistryKey Root="HKCR" Key=".jxl\shellex\{e357fccd-a995-4576-b01f-234630154e96}" Condition="HAS_LIBJXL">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
        
        <!-- 3D Models (Sprint 12) -->
        <RegistryKey Root="HKCR" Key=".obj\shellex\{e357fccd-a995-4576-b01f-234630154e96}">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
        
        <RegistryKey Root="HKCR" Key=".stl\shellex\{e357fccd-a995-4576-b01f-234630154e96}">
          <RegistryValue Value="{A8394D0D-EE2B-4A00-9FAC-AB8D3B03F078}" Type="string" />
        </RegistryKey>
      </Component>
      
      <!-- Configuration Registry -->
      <Component Id="ConfigurationRegistry" Guid="58394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <RegistryKey Root="HKLM" Key="SOFTWARE\DarkThumbs">
          <RegistryValue Name="InstallPath" Value="[INSTALLFOLDER]" Type="string" />
          <RegistryValue Name="Version" Value="6.2.0" Type="string" />
          <RegistryValue Name="CacheMaxSizeMB" Value="500" Type="integer" />
          <RegistryValue Name="GPUEnabled" Value="1" Type="integer" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
    
    <!-- Start Menu Shortcuts -->
    <ComponentGroup Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="68394D0D-EE2B-4A00-9FAC-AB8D3B03F078">
        <Shortcut Id="CBXManagerShortcut"
                  Name="DarkThumbs Manager"
                  Description="Configure DarkThumbs thumbnail settings"
                  Target="[BinFolder]CBXManager.exe"
                  WorkingDirectory="BinFolder"
                  Icon="AppIcon.exe" />
        
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
        
        <RegistryValue Root="HKCU"
                       Key="Software\DarkThumbs"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
  
  <!-- Icons -->
  <Fragment>
    <Icon Id="AppIcon.exe" SourceFile="$(var.BuildDir)\CBXManager\CBXManager.exe" />
  </Fragment>
  
  <!-- UI Configuration -->
  <Fragment>
    <UI Id="WixUI_FeatureTree">
      <UIRef Id="WixUI_FeatureTree" />
      <UIRef Id="WixUI_ErrorProgressText" />
      
      <!-- License Agreement -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="LicenseAgreementDlg">1</Publish>
      <Publish Dialog="LicenseAgreementDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg">1</Publish>
    </UI>
    
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.BuildDir)\LICENSE.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="$(var.BuildDir)\packaging\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="$(var.BuildDir)\packaging\dialog.bmp" />
  </Fragment>
  
  <!-- Custom Actions -->
  <Fragment>
    <!-- Refresh Windows Explorer after installation -->
    <CustomAction Id="RefreshExplorer"
                  BinaryKey="WixCA"
                  DllEntry="WixShellExec"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    
    <InstallExecuteSequence>
      <Custom Action="RefreshExplorer" Before="InstallFinalize">NOT REMOVE</Custom>
    </InstallExecuteSequence>
  </Fragment>
  
</Wix>
