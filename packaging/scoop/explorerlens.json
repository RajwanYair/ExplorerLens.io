{
  "version": "39.2.0",
  "description": "ExplorerLens — GPU-accelerated thumbnail provider for Windows Explorer (200+ file formats). Codename Betelgeuse.",
  "homepage": "https://github.com/RajwanYair/ExplorerLens.io",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/RajwanYair/ExplorerLens.io/releases/download/v39.2.0/ExplorerLens-39.2.0-Portable.zip",
      "hash": "590cd89bff1ea315f588956926761770b51f30de0a6b663b6509839942ec4042",
      "extract_dir": "ExplorerLens-39.2.0-Portable"
    }
  },
  "bin": [
    "LENSManager.exe"
  ],
  "shortcuts": [
    ["LENSManager.exe", "ExplorerLens Manager"]
  ],
  "post_install": [
    "Write-Host 'Registering LENSShell.dll...' -ForegroundColor Cyan",
    "$dll = \"$dir\\LENSShell.dll\"",
    "if (Test-Path $dll) { Start-Process regsvr32.exe -ArgumentList '/s', $dll -Wait }"
  ],
  "pre_uninstall": [
    "$dll = \"$dir\\LENSShell.dll\"",
    "if (Test-Path $dll) { Start-Process regsvr32.exe -ArgumentList '/s', '/u', $dll -Wait }"
  ],
  "checkver": {
    "github": "https://github.com/RajwanYair/ExplorerLens.io",
    "regex": "v([\\d.]+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/RajwanYair/ExplorerLens.io/releases/download/v$version/ExplorerLens-$version-Portable.zip",
        "hash": {
          "url": "https://github.com/RajwanYair/ExplorerLens.io/releases/download/v$version/SHA256SUMS-$version.txt",
          "regex": "([A-Fa-f0-9]+)\\s+ExplorerLens-$version-Portable.zip"
        },
        "extract_dir": "ExplorerLens-$version-Portable"
      }
    }
  }
}
