# Doxyfile — ExplorerLens Engine API Documentation
# Generated for Doxygen 1.12+ (download from https://www.doxygen.nl/)
# Run: doxygen docs/Doxyfile

#---------------------------------------------------------------------------
# Project related
#---------------------------------------------------------------------------
PROJECT_NAME           = "ExplorerLens Engine"
PROJECT_NUMBER         = "15.0.0"
PROJECT_BRIEF          = "GPU-accelerated thumbnail generation for 200+ file formats"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = docs/api
CREATE_SUBDIRS         = YES
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

#---------------------------------------------------------------------------
# Build related
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
RESOLVE_UNNAMED_PARAMS = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = YES
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = Engine/
SHORT_NAMES            = NO
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
GROUP_NESTED_COMPOUNDS = YES
TYPEDEF_HIDES_STRUCT   = NO
LOOKUP_CACHE_SIZE      = 2

#---------------------------------------------------------------------------
# Input related
#---------------------------------------------------------------------------
INPUT                  = Engine/ SDK/
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.cpp *.hpp *.md
RECURSIVE              = YES
EXCLUDE                = Engine/Tests/ build/ external/
EXCLUDE_PATTERNS       = */build/* */external/* */.git/*
EXCLUDE_SYMLINKS       = YES

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
USE_HTAGS              = NO
VERBATIM_HEADERS       = NO

#---------------------------------------------------------------------------
# Preprocessor
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = WIN32_LEAN_AND_MEAN \
                         HAS_LIBJXL=1 \
                         HAS_LIBHEIF=1 \
                         HAS_LIBRAW=1 \
                         HAS_LIBAVIF=1 \
                         HAS_MUPDF=1 \
                         HAS_OPENJPEG=1 \
                         HAS_FREETYPE=1 \
                         HAS_LIBARCHIVE=0 \
                         PLUGIN_API=__declspec(dllexport)

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 280
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

#---------------------------------------------------------------------------
# LaTeX output (disabled)
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Other outputs
#---------------------------------------------------------------------------
GENERATE_XML           = YES
XML_OUTPUT             = xml
GENERATE_MAN           = NO
GENERATE_RTF           = NO

#---------------------------------------------------------------------------
# Dot graphs (requires Graphviz)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = docs/doxygen-warnings.log
