{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "description": "Bundled vcpkg from VS 18 BuildTools",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/Program Files (x86)/Microsoft Visual Studio/18/BuildTools/VC/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    },
    {
      "name": "msvc-v145",
      "hidden": true,
      "description": "MSVC v145 toolset (cl.exe 19.50) from VS 18 2026 BuildTools + Ninja",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "C:/Users/ryair/scoop/shims/ninja.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_LINKER": "C:/Program Files (x86)/Microsoft Visual Studio/18/BuildTools/VC/Tools/MSVC/14.50.35717/bin/Hostx64/x64/link.exe",
        "CMAKE_AR": "C:/Program Files (x86)/Microsoft Visual Studio/18/BuildTools/VC/Tools/MSVC/14.50.35717/bin/Hostx64/x64/lib.exe",
        "CMAKE_MT": "C:/Program Files (x86)/Windows Kits/10/bin/10.0.26100.0/x64/mt.exe",
        "CMAKE_RC_COMPILER": "C:/Program Files (x86)/Windows Kits/10/bin/10.0.26100.0/x64/rc.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL",
        "CMAKE_SYSTEM_VERSION": "10.0.26100.0",
        "BUILD_SHARED_LIBS": "FALSE"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": "Windows",
          "intelliSenseMode": "windows-msvc-x64",
          "enableMicrosoftCodeAnalysis": true
        }
      }
    },
    {
      "name": "vcpkg-release",
      "displayName": "Release (vcpkg + MSVC v145 + Ninja)",
      "description": "Fast Release build using vcpkg dependencies, MSVC v145, and Ninja",
      "inherits": [
        "vcpkg-base",
        "msvc-v145"
      ],
      "binaryDir": "${sourceDir}/build-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "vcpkg-debug",
      "displayName": "Debug (vcpkg + MSVC v145 + Ninja)",
      "description": "Debug build with vcpkg dependencies for development",
      "inherits": [
        "vcpkg-base",
        "msvc-v145"
      ],
      "binaryDir": "${sourceDir}/build-vcpkg-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "default-release",
      "displayName": "Release (MSVC v145 + Ninja)",
      "description": "Standard Release build with Ninja — no vcpkg, local external libs",
      "inherits": "msvc-v145",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "default-debug",
      "displayName": "Debug (MSVC v145 + Ninja)",
      "description": "Standard Debug build with Ninja — no vcpkg, local external libs",
      "inherits": "msvc-v145",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "vs2026",
      "displayName": "Visual Studio 18 2026 (MSBuild v145)",
      "description": "Traditional VS build using MSBuild with v145 toolset",
      "generator": "Visual Studio 18 2026",
      "toolset": "v145",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-vs",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_SYSTEM_VERSION": "10.0.26100.0"
      }
    },
    {
      "name": "ci-release",
      "displayName": "CI Release (GitHub Actions)",
      "description": "Release build for CI runners — tool paths resolved via vcvars64, no hardcoded local paths",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_SHARED_LIBS": "FALSE"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vcpkg-release",
      "displayName": "Build Release (vcpkg)",
      "configurePreset": "vcpkg-release",
      "configuration": "Release",
      "jobs": 8,
      "verbose": false
    },
    {
      "name": "vcpkg-debug",
      "displayName": "Build Debug (vcpkg)",
      "configurePreset": "vcpkg-debug",
      "configuration": "Debug",
      "jobs": 8,
      "verbose": false
    },
    {
      "name": "ci-release",
      "displayName": "Build CI Release (GitHub Actions)",
      "configurePreset": "ci-release",
      "configuration": "Release",
      "jobs": 8,
      "verbose": false
    },
    {
      "name": "default-release",
      "displayName": "Build Release (Default)",
      "configurePreset": "default-release",
      "configuration": "Release",
      "jobs": 8,
      "verbose": false
    },
    {
      "name": "default-debug",
      "displayName": "Build Debug (Default)",
      "configurePreset": "default-debug",
      "configuration": "Debug",
      "jobs": 8,
      "verbose": false
    },
    {
      "name": "vs2026-release",
      "displayName": "Build Release (VS 2026)",
      "configurePreset": "vs2026",
      "configuration": "Release"
    },
    {
      "name": "vs2026-debug",
      "displayName": "Build Debug (VS 2026)",
      "configurePreset": "vs2026",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "default-release-test",
      "displayName": "Test Release (Default)",
      "configurePreset": "default-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "vcpkg-release-test",
      "displayName": "Test Release (vcpkg)",
      "configurePreset": "vcpkg-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "vcpkg-debug-test",
      "displayName": "Test Debug (vcpkg)",
      "configurePreset": "vcpkg-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "ignore",
        "stopOnFailure": false
      }
    }
  ],
  "vendor": {
    "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
      "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
    }
  }
}
