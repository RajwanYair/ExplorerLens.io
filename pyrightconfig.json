{
  // ==========================================================================
  // GENERIC PYRIGHT / PYLANCE CONFIGURATION
  // Universal Project Enhancement Framework v12.0.0
  // ==========================================================================
  //
  // Scope: Workspace-level defaults for all Python projects.
  // Override in project-specific pyrightconfig.json for stricter settings.
  //
  // Reference: https://github.com/microsoft/pyright/blob/main/docs/configuration.md
  // ==========================================================================
  "pythonVersion": "3.9",
  "typeCheckingMode": "basic",
  // Search paths — include common source layouts
  "extraPaths": [
    ".",
    "src",
    "src/core",
    "src/cli",
    "src/gui",
    "src/utils"
  ],
  // ==========================================================================
  // WORKSPACE EXCLUSIONS
  // ==========================================================================
  "exclude": [
    "**/node_modules",
    "**/.venv",
    "**/venv",
    "**/build",
    "**/dist",
    "**/.mypy_cache",
    "**/__pycache__",
    "**/external",
    "**/archive",
    "**/*.egg-info"
  ],
  // ==========================================================================
  // TYPE STUBS & IMPORT RESOLUTION
  // ==========================================================================
  // Don't error when stub source is unavailable (cross-platform modules)
  "reportMissingModuleSource": false,
  // Third-party packages without stubs are expected
  "reportMissingTypeStubs": false,
  // ==========================================================================
  // JUSTIFIED SUPPRESSIONS (architectural / platform reasons)
  // ==========================================================================
  // Type-ignores are usually intentional for platform-specific code
  "reportUnnecessaryTypeIgnoreComment": false,
  // Unused parameters are common in callbacks and plugin APIs
  "reportUnusedParameter": false,
  // tkinter, ctypes, and win32 return values we intentionally discard
  "reportUnusedCallResult": false,
  // Dynamic attributes common in tkinter/ctypes/win32
  "reportAttributeAccessIssue": false,
  // Tests legitimately access private members for validation
  "reportPrivateUsage": false,
  // Patch decorators and dynamic decorators lack full type stubs
  "reportUntypedFunctionDecorator": false,
  // Implicit string concatenation used for long paths/messages
  "reportImplicitStringConcatenation": false,
  // ctypes/tkinter dynamic members lack full type information
  "reportUnknownMemberType": false,
  // Optional member access patterns are validated at runtime
  "reportOptionalMemberAccess": false,
  // Third-party packages installed only at runtime (pystray, etc.)
  "reportMissingImports": false
}
