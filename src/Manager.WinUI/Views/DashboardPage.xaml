<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DarkThumbs.Manager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24"
                Spacing="24">

            <!-- Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="Dashboard"
                        Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.EngineStatus, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Status Cards -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cache Status -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8B7;"
                                FontSize="32"
                                Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock Text="Cache"
                                Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.CacheStats.TotalEntries, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.CacheStats.HitRate, Mode=OneWay, Converter={StaticResource PercentageFormatter}}"/>
                            <Run Text="% hit rate"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Performance Status -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE9D9;"
                                FontSize="32"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="Performance"
                                Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.PerformanceSummary.AverageThroughput, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="thumbnails/sec"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Plugins Status -->
                <Border Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE74C;"
                                FontSize="32"
                                Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                        <TextBlock Text="Plugins"
                                Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.InstalledPluginsCount, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Text="installed"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Errors Status -->
                <Border Grid.Column="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE783;"
                                FontSize="32"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        <TextBlock Text="Errors"
                                Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.RecentErrorCount, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Text="recent"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- GPU Status -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Visibility="{x:Bind ViewModel.PerformanceSummary.GpuStatus.Available, Mode=OneWay}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Grid.Column="0"
                            Glyph="&#xE950;"
                            FontSize="48"
                            VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                            Spacing="12">
                        <TextBlock Text="GPU Acceleration"
                                Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.PerformanceSummary.GpuStatus.DeviceName, Mode=OneWay}"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.PerformanceSummary.GpuStatus.UsagePercent, Mode=OneWay}"
                                     Maximum="100"
                                     ShowError="False"
                                     ShowPaused="False"/>
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.PerformanceSummary.GpuStatus.UsagePercent, Mode=OneWay}"/>
                            <Run Text="% usage •"/>
                            <Run Text="{x:Bind ViewModel.PerformanceSummary.GpuStatus.MemoryUsedBytes, Mode=OneWay, Converter={StaticResource BytesFormatter}}"/>
                            <Run Text="/"/>
                            <Run Text="{x:Bind ViewModel.PerformanceSummary.GpuStatus.MemoryTotalBytes, Mode=OneWay, Converter={StaticResource BytesFormatter}}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick Actions -->
            <StackPanel Spacing="12">
                <TextBlock Text="Quick Actions"
                        Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE8B7;"
                                    FontSize="24"/>
                            <TextBlock Text="Clear Cache"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE8C5;"
                                    FontSize="24"/>
                            <TextBlock Text="Export Diagnostics"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE72C;"
                                    FontSize="24"/>
                            <TextBlock Text="Refresh Status"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
