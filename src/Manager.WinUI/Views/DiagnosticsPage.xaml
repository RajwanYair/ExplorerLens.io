<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DarkThumbs.Manager.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
                Padding="24,24,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Diagnostics"
                        Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0"
                           Visibility="{x:Bind ViewModel.Summary, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Run Text="{x:Bind ViewModel.Summary.ErrorCount, Mode=OneWay}"/>
                    <Run Text="errors •"/>
                    <Run Text="{x:Bind ViewModel.Summary.WarningCount, Mode=OneWay}"/>
                    <Run Text="warnings •"/>
                    <Run Text="Status:"/>
                    <Run Text="{x:Bind ViewModel.Summary.EngineStatus, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                <ToggleSwitch Header="Auto-refresh"
                              IsOn="{x:Bind ViewModel.AutoRefresh, Mode=TwoWay}"
                              OffContent=""
                        OnContent=""/>
                <Button Content="Export Bundle"
                        Command="{x:Bind ViewModel.ExportDiagnosticsBundleCommand}">
                    <Button.Icon>
                        <FontIcon Glyph="&#xE8C5;"/>
                    </Button.Icon>
                </Button>
                <Button Content="Refresh"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                    <Button.Icon>
                        <FontIcon Glyph="&#xE72C;"/>
                    </Button.Icon>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <TabView Grid.Row="1"
                Margin="12,0">

            <!-- Logs Tab -->
            <TabViewItem Header="Logs"
                    IconSource="Document">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Filters -->
                    <Grid Grid.Row="0"
                            Padding="12"
                            ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  Header="Level"
                                  ItemsSource="{x:Bind ViewModel.LogLevels}"
                                  SelectedItem="{x:Bind ViewModel.SelectedLogLevel, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>

                        <TextBox Grid.Column="1"
                                 Header="Filter"
                                 PlaceholderText="Filter by message or correlation ID..."
                                 Text="{x:Bind ViewModel.FilterText, Mode=TwoWay}"/>
                    </Grid>

                    <!-- Logs List -->
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Logs}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:LogEntry">
                                <Grid Padding="8"
                                        ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind Timestamp, Converter={StaticResource DateTimeFormatter}}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="1"
                                            Background="{x:Bind Level, Converter={StaticResource LogLevelToColorConverter}}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Level}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="White"/>
                                    </Border>

                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Category}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind Message}"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind CorrelationId}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center"
                                               Visibility="{x:Bind CorrelationId, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Actions -->
                    <CommandBar Grid.Row="2"
                            DefaultLabelPosition="Right">
                        <AppBarButton Icon="Delete"
                                Label="Clear Logs"
                                Command="{x:Bind ViewModel.ClearLogsCommand}"/>
                        <AppBarButton Icon="Save"
                                Label="Export Logs"/>
                    </CommandBar>
                </Grid>
            </TabViewItem>

            <!-- Performance Tab -->
            <TabViewItem Header="Performance"
                    IconSource="SpeedHigh">
                <ScrollViewer Padding="12">
                    <StackPanel Spacing="16"
                            Visibility="{x:Bind ViewModel.PerformanceMetrics, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">

                        <!-- Summary Cards -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Average Time -->
                            <Border Grid.Column="0"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Average Time"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Style="{StaticResource TitleTextBlockStyle}">
                                        <Run Text="{x:Bind ViewModel.PerformanceMetrics.AverageThumbnailTimeMs, Mode=OneWay}"/>
                                        <Run Text="ms"
                                                Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- P95 Time -->
                            <Border Grid.Column="1"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="P95 Time"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Style="{StaticResource TitleTextBlockStyle}">
                                        <Run Text="{x:Bind ViewModel.PerformanceMetrics.P95ThumbnailTimeMs, Mode=OneWay}"/>
                                        <Run Text="ms"
                                                Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Total Requests -->
                            <Border Grid.Column="2"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Total Requests"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.PerformanceMetrics.TotalRequests, Mode=OneWay}"
                                               Style="{StaticResource TitleTextBlockStyle}"/>
                                </StackPanel>
                            </Border>

                            <!-- Cache Hit Rate -->
                            <Border Grid.Column="3"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Cache Hit Rate"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Style="{StaticResource TitleTextBlockStyle}">
                                        <Run Text="{x:Bind ViewModel.PerformanceMetrics.CacheHitRate, Mode=OneWay, Converter={StaticResource PercentageFormatter}}"/>
                                        <Run Text="%"
                                                Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Performance Chart Placeholder -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Height="300">
                            <Grid>
                                <TextBlock Text="Performance chart visualization will go here"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- Errors Tab -->
            <TabViewItem Header="Errors"
                    IconSource="ReportHacked">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView Grid.Row="0"
                              ItemsSource="{x:Bind ViewModel.Errors}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ErrorReport">
                                <Grid Padding="12"
                                        ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Grid.Column="0"
                                              Glyph="&#xE783;"
                                              FontSize="24"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                              VerticalAlignment="Top"
                                              Margin="0,4,0,0"/>

                                    <StackPanel Grid.Column="1"
                                            Spacing="4">
                                        <TextBlock Text="{x:Bind Timestamp, Converter={StaticResource DateTimeFormatter}}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ErrorCode}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind Message}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind FilePath}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{x:Bind FilePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock Grid.Row="0"
                               Text="No errors reported"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind ViewModel.Errors.Count, Mode=OneWay, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </Grid>
            </TabViewItem>

        </TabView>

        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48"
                Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
    </Grid>
</Page>
