<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DarkThumbs.Manager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                Padding="24,24,24,12">
            <TextBlock Text="Settings"
                    Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Configure DarkThumbs behavior and preferences"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="24,0,24,24"
                    Spacing="24">

                <!-- General Settings -->
                <StackPanel Spacing="8">
                    <TextBlock Text="General"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Spacing="12"
                            Margin="0,8,0,0">
                        <ToggleSwitch Header="Dark Mode"
                                      IsOn="{x:Bind ViewModel.DarkMode, Mode=TwoWay}"/>

                        <ToggleSwitch Header="Start with Windows"
                                      IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"/>

                        <ToggleSwitch Header="Minimize to System Tray"
                                      IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"/>

                <!-- Cache Settings -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Cache"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Spacing="12"
                            Margin="0,8,0,0">
                        <NumberBox Header="Maximum Cache Size (MB)"
                                   Value="{x:Bind ViewModel.CacheMaxSizeMB, Mode=TwoWay}"
                                   Minimum="100"
                                   Maximum="102400"
                                   SpinButtonPlacementMode="Inline"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Cache Location"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                        Text="{x:Bind ViewModel.CacheLocation, Mode=TwoWay}"/>
                                <Button Grid.Column="1"
                                        Content="Browse..."
                                        Command="{x:Bind ViewModel.BrowseCacheLocationCommand}"/>
                            </Grid>
                        </StackPanel>

                        <NumberBox Header="Retention Period (Days)"
                                   Value="{x:Bind ViewModel.CacheRetentionDays, Mode=TwoWay}"
                                   Minimum="1"
                                   Maximum="365"
                                   SpinButtonPlacementMode="Inline"/>

                        <ToggleSwitch Header="Auto-clear expired entries"
                                      IsOn="{x:Bind ViewModel.AutoClearCache, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"/>

                <!-- GPU Settings -->
                <StackPanel Spacing="8">
                    <TextBlock Text="GPU Acceleration"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Spacing="12"
                            Margin="0,8,0,0">
                        <ToggleSwitch Header="Enable GPU Acceleration"
                                      IsOn="{x:Bind ViewModel.GpuAccelerationEnabled, Mode=TwoWay}"/>

                        <ComboBox Header="GPU Device"
                                  ItemsSource="{x:Bind ViewModel.AvailableGpuDevices}"
                                  SelectedItem="{x:Bind ViewModel.SelectedGpuDevice, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.GpuAccelerationEnabled, Mode=OneWay}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"/>

                <!-- Format Settings -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Formats"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Spacing="12"
                            Margin="0,8,0,0">
                        <ToggleSwitch Header="Prefer Native Decoders"
                                      Description="Use platform decoders (WIC, DirectX) when available"
                                      IsOn="{x:Bind ViewModel.PreferNativeDecoders, Mode=TwoWay}"/>

                        <ToggleSwitch Header="Enable Experimental Formats"
                                      Description="Support bleeding-edge formats (may be unstable)"
                                      IsOn="{x:Bind ViewModel.EnableExperimentalFormats, Mode=TwoWay}"/>

                        <NumberBox Header="Maximum Thumbnail Size (px)"
                                   Value="{x:Bind ViewModel.MaxThumbnailSize, Mode=TwoWay}"
                                   Minimum="256"
                                   Maximum="4096"
                                   SpinButtonPlacementMode="Inline"/>
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"/>

                <!-- Plugin Settings -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Plugins"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Spacing="12"
                            Margin="0,8,0,0">
                        <ToggleSwitch Header="Enable Plugins"
                                      IsOn="{x:Bind ViewModel.EnablePlugins, Mode=TwoWay}"/>

                        <ToggleSwitch Header="Only Load Trusted Plugins"
                                      Description="Require signature verification"
                                      IsOn="{x:Bind ViewModel.OnlyTrustedPlugins, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.EnablePlugins, Mode=OneWay}"/>

                        <ComboBox Header="Plugin Isolation Mode"
                                  ItemsSource="{x:Bind ViewModel.IsolationModes}"
                                  SelectedItem="{x:Bind ViewModel.PluginIsolationMode, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.EnablePlugins, Mode=OneWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.Description>
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="In-Worker: Fastest, least secure"/>
                                    <LineBreak/>
                                    <Run Text="PluginHost: Balanced"/>
                                    <LineBreak/>
                                    <Run Text="AppContainer: Slowest, most secure"/>
                                </TextBlock>
                            </ComboBox.Description>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"/>

                <!-- Advanced Settings -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Advanced"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Spacing="12"
                            Margin="0,8,0,0">
                        <ToggleSwitch Header="Enable Logging"
                                      IsOn="{x:Bind ViewModel.EnableLogging, Mode=TwoWay}"/>

                        <ComboBox Header="Log Level"
                                  ItemsSource="{x:Bind ViewModel.LogLevels}"
                                  SelectedItem="{x:Bind ViewModel.LogLevel, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.EnableLogging, Mode=OneWay}"
                                  HorizontalAlignment="Stretch"/>

                        <ToggleSwitch Header="Enable Performance Monitoring"
                                      Description="Track thumbnail generation metrics"
                                      IsOn="{x:Bind ViewModel.EnablePerformanceMonitoring, Mode=TwoWay}"/>

                        <ToggleSwitch Header="Enable Experimental Features"
                                      Description="Access bleeding-edge features (may be unstable)"
                                      IsOn="{x:Bind ViewModel.EnableExperimentalFeatures, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Bar -->
        <Grid Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0"
              Padding="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="You have unsaved changes"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                       Visibility="{x:Bind ViewModel.HasUnsavedChanges, Mode=OneWay}"/>

            <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                <Button Content="Reset to Defaults"
                        Command="{x:Bind ViewModel.ResetToDefaultsCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>

                <Button Content="Apply"
                        Command="{x:Bind ViewModel.ApplySettingsCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.HasUnsavedChanges, Mode=OneWay}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
