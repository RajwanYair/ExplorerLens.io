<Window
    x:Class="DarkThumbs.Manager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Auto" Loaded="NavView_Loaded" ItemInvoked="NavView_ItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Dashboard" Tag="DashboardPage" />
                <NavigationViewItem Icon="Pictures" Content="Formats" Tag="FormatsPage" />
                <NavigationViewItem Icon="Shop" Content="Marketplace" Tag="MarketplacePage" />
                <NavigationViewItem Icon="Admin" Content="Policies" Tag="PoliciesPage" />
                <NavigationViewItem Icon="Repair" Content="Diagnostics" Tag="DiagnosticsPage" />
            </NavigationView.MenuItems>
            
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
