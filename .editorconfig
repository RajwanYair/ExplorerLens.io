# ExplorerLens.io — EditorConfig
# https://editorconfig.org
root = true

# Default for all files
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C/C++ source files
[*.{h,cpp,c,hpp,inl}]
indent_size = 4
max_line_length = 120

# CMake files
[{CMakeLists.txt,*.cmake}]
indent_size = 4

# PowerShell scripts
[*.{ps1,psm1,psd1}]
indent_size = 4

# JSON/JSONC configuration
[*.{json,jsonc}]
indent_size = 4

# YAML (GitHub Actions)
[*.{yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# XML / manifest / resource files
[*.{xml,manifest,rc,props,targets,vcxproj}]
indent_size = 2

# Batch / CMD
[*.{bat,cmd}]
end_of_line = crlf

# WiX / Inno Setup
[*.{wxs,wxi,iss}]
indent_size = 2

# Solution files
[*.sln]
indent_style = tab
