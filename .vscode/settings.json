    // ── CMake Tools ──────────────────────────────────────────────
    "cmake.sourceDirectory": "${workspaceFolder}",
    "cmake.useCMakePresets": "always",
    "cmake.generator": "Ninja",
    "cmake.configureOnOpen": false,\n    "cmake.configureArgs": [],\n    "cmake.defaultConfigurePreset": "default-release",\n    "cmake.defaultBuildPreset": "default-release",\n    "cmake.defaultTestPreset": "default-release-test",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureSettings": {
        "CMAKE_MAKE_PROGRAM": "C:/Users/ryair/scoop/shims/ninja.exe"
    },
    "cmake.configureOnEdit": false,
    "cmake.automaticReconfigure": false,
    "cmake.allowCommentsInPresetsFile": true,
    "cmake.options.statusBarVisibility": "visible",
    "cmake.configureEnvironment": {
        "CMAKE_GENERATOR_PLATFORM": "x64"
    },
    "cmake.buildBeforeRun": true,
    "cmake.ctest.allowParallelJobs": true,
    "cmake.parallelJobs": 8,
    "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
    // ── C/C++ IntelliSense ───────────────────────────────────────
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.autocomplete": "Default",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.default.intelliSenseMode": "windows-msvc-x64",
    "C_Cpp.default.compilerPath": "C:/Program Files (x86)/Microsoft Visual Studio/18/BuildTools/VC/Tools/MSVC/14.50.35717/bin/Hostx64/x64/cl.exe",
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
    "C_Cpp.default.defines": [
        "WIN32_LEAN_AND_MEAN",
        "NOMINMAX",
        "UNICODE",
        "_UNICODE",
        "_WIN64",
        "_AMD64_",
        "NDEBUG"
    ],
    "C_Cpp.codeAnalysis.runAutomatically": true,
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.enhancedColorization": "enabled",
    "C_Cpp.formatting": "vcFormat",
    "C_Cpp.vcFormat.indent.braces": false,
    "C_Cpp.vcFormat.indent.namespaceContents": false,
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.function": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.block": "sameLine",
    // ── File Associations ────────────────────────────────────────
    "files.associations": {
        "xstring": "cpp",
        "algorithm": "cpp",
        "*.h.in": "cpp",
        "*.h": "cpp",
        "*.cmake": "cmake",
        "CMakeLists.txt": "cmake",
        "*.ps1": "powershell",
        "*.psm1": "powershell",
        "*.manifest": "xml",
        "*.rc": "cpp",
        "*.def": "cpp"
    },
    // ── Editor ───────────────────────────────────────────────────
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.parameterHints.enabled": true,
    "editor.formatOnSave": false,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        120
    ],
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.stickyScroll.enabled": true,
    // ── Files ────────────────────────────────────────────────────
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.encoding": "utf8",
    "files.eol": "\r\n",
    "files.exclude": {
        "**/.vs": true,
        "**/x64/Debug": true,
        "**/ipch": true,
        "**/*.user": true,
        "**/*.suo": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true,
        "**/build/**": true,
        "**/build-vcpkg/**": true,
        "**/x64/**": true,
        "**/external/**/build*": true,
        "**/external/**/src/**": true,
        "**/packages/**": true,
        "**/gtest/**": true,
        "**/build-logs": false
    },
    // ── Search ───────────────────────────────────────────────────
    "search.exclude": {
        "**/build": true,
        "**/build-vcpkg": true,
        "**/x64": true,
        "**/external/**/build*": true,
        "**/external/**/src/**": true,
        "**/packages": true,
        "**/.vs": true,
        "**/gtest": true,
        "**/*.obj": true,
        "**/*.pdb": true,
        "**/*.lib": true,
        "**/*.exe": true,
        "**/*.dll": true,
        "**/build-logs": false
    },
    // ── Terminal ──────────────────────────────────────────────────
    "terminal.integrated.defaultProfile.windows": "ExplorerLens Dev",
    "terminal.integrated.profiles.windows": {
        "ExplorerLens Dev": {
            "path": "pwsh.exe",
            "icon": "tools",
            "args": [
                "-NoProfile",
                "-NoLogo",
                "-NoExit",
                "-File",
                "${env:USERPROFILE}\\OneDrive - Intel Corporation\\Documents\\MyScripts\\ExplorerLens.io\\.env.ps1"
            ]
        },
        "PowerShell 7": {
            "path": "pwsh.exe",
            "icon": "terminal-powershell",
            "args": [
                "-NoProfile",
                "-NoLogo"
            ]
        },
        "Developer PowerShell (vcvars64)": {
            "path": "pwsh.exe",
            "icon": "terminal-powershell",
            "args": [
                "-NoProfile",
                "-NoLogo",
                "-NoExit",
                "-Command",
                "& cmd /c '\"C:\\Program Files (x86)\\Microsoft Visual Studio\\18\\BuildTools\\VC\\Auxiliary\\Build\\vcvars64.bat\" -vcvars_ver=14.50.35717 >nul 2>&1 && set' | ForEach-Object { if ($_ -match '^(.+?)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }; Write-Host '✓ MSVC v145 environment loaded' -ForegroundColor Green"
            ]
        },
        "PowerShell (Legacy)": {
            "source": "PowerShell",
            "icon": "terminal-powershell",
            "args": [
                "-NoProfile",
                "-NoLogo"
            ]
        }
    },
    "terminal.integrated.env.windows": {
        "MSBUILDDISABLENODEREUSE": "1"
    },
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.shellIntegration.decorationsEnabled": "both",
    "terminal.integrated.automationProfile.windows": {
        "path": "pwsh.exe",
        "args": [
            "-NoProfile",
            "-NoLogo"
        ]
    },
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.scrollback": 50000,
    "terminal.integrated.fastScrollSensitivity": 5,
    "terminal.integrated.commandsToSkipShell": [],
    "terminal.integrated.confirmOnKill": "always",
    "terminal.integrated.allowChords": true,
    "terminal.integrated.detectLocale": "auto",
    "terminal.integrated.gpuAcceleration": "auto",
    "terminal.integrated.cwd": "${workspaceFolder}",
    // ── Tasks & Build ────────────────────────────────────────────
    "task.slowProviderWarning": false,
    "task.autoDetect": "off",
    // ── Git ──────────────────────────────────────────────────────
    "git.autorefresh": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    // ── Markdown ─────────────────────────────────────────────────
